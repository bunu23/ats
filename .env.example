# ATS Application - Environment Variables
# Copy this file to .env.local and fill in the values before running the application

# AI Provider Settings
# Options: 'mock' (default) or 'claude'
AI_PROVIDER=mock

# Anthropic API Key (Required if AI_PROVIDER is set to 'claude')
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Port configuration (Optional)
# PORT=3000
